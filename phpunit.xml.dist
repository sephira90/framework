<?xml version="1.0" encoding="UTF-8"?>
<phpunit
    bootstrap="vendor/autoload.php"
    cacheDirectory="var/phpunit"
    colors="true"
    testdox="false"
>
    <testsuites>
        <testsuite name="Framework">
            <directory>tests</directory>
        </testsuite>
    </testsuites>
</phpunit>
