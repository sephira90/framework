{
    "name": "sephira90/framework",
    "description": "Systematically developed PHP framework core.",
    "type": "project",
    "license": "proprietary",
    "require": {
        "nyholm/psr7": "^1.8",
        "nyholm/psr7-server": "^1.1",
        "php": "^8.4",
        "psr/container": "^2.0",
        "psr/http-factory": "^1.1",
        "psr/http-message": "^2.0",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "php-parallel-lint/php-parallel-lint": "^1.4",
        "phpunit/phpunit": "^11.5",
        "phpstan/phpstan": "^2.1",
        "squizlabs/php_codesniffer": "^3.11",
        "vimeo/psalm": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Framework\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Framework\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": "@php qa.php lint",
        "cs": "@php qa.php cs",
        "phpstan": "@php qa.php phpstan",
        "psalm": "@php qa.php psalm",
        "qa": "@php qa.php qa",
        "test": "@php vendor/bin/phpunit --configuration phpunit.xml.dist"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
